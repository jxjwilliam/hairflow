{
  "1": {
    "class_type": "LoadImage",
    "inputs": { "image": "__IMAGE_FILENAME__" }
  },
  "2": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["1", 0],
      "upscale_method": "lanczos",
      "width": 512,
      "height": 768,
      "crop": "center"
    }
  },
  "3": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "ltx-video-2b-v0.9.5.safetensors" }
  },
  "4": {
    "class_type": "CLIPLoader",
    "inputs": { "clip_name": "t5xxl_fp16.safetensors", "type": "ltxv" }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "A person with a clear face and detailed hairstyle, subtle natural hair movement, soft gentle head turn, cinematic portrait lighting, keep the exact same face identity and hairstyle, high quality, smooth motion",
      "clip": ["4", 0]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "low quality, worst quality, deformed, distorted, disfigured, motion smear, motion artifacts, morphing face, identity change, flicker, watermark, text, ugly",
      "clip": ["4", 0]
    }
  },
  "7": {
    "class_type": "LTXVPreprocess",
    "inputs": { "image": ["2", 0], "img_compression": 35 }
  },
  "8": {
    "class_type": "LTXVImgToVideo",
    "inputs": {
      "positive": ["5", 0],
      "negative": ["6", 0],
      "vae": ["3", 2],
      "image": ["7", 0],
      "width": 512,
      "height": 768,
      "length": "__FRAME_COUNT_WITH_INITIAL__",
      "batch_size": 1,
      "strength": 1.0
    }
  },
  "9": {
    "class_type": "LTXVConditioning",
    "inputs": {
      "positive": ["8", 0],
      "negative": ["8", 1],
      "frame_rate": "__FPS__"
    }
  },
  "10": {
    "class_type": "LTXVScheduler",
    "inputs": {
      "steps": 20,
      "max_shift": 2.05,
      "base_shift": 0.95,
      "stretch": true,
      "terminal": 0.1,
      "latent": ["8", 2]
    }
  },
  "11": {
    "class_type": "KSamplerSelect",
    "inputs": { "sampler_name": "euler" }
  },
  "12": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["3", 0],
      "add_noise": true,
      "noise_seed": "__SEED__",
      "cfg": 3.0,
      "positive": ["9", 0],
      "negative": ["9", 1],
      "sampler": ["11", 0],
      "sigmas": ["10", 0],
      "latent_image": ["8", 2]
    }
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["12", 0], "vae": ["3", 2] }
  },
  "14": {
    "class_type": "CreateVideo",
    "inputs": { "images": ["13", 0], "fps": "__FPS__" }
  },
  "15": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["14", 0],
      "filename_prefix": "hairflow/ltx",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
