# Primary — local ComfyUI (required for /api/comfyui/generate)
COMFYUI_URL=http://127.0.0.1:8188

# Legacy Meitu path (/api/generate) — unused by the mobile app
MEITU_API_KEY=your_key_here
MEITU_API_SECRET=your_secret_here
MEITU_API_APPID=your_appid_here

# Optional OSS (ComfyUI path saves to backend/output/ by default)
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=your-bucket
OSS_ACCESS_KEY=your_ak
OSS_SECRET_KEY=your_sk

# Unused — face detection uses MediaPipe locally
ALI_CLOUD_VISION_KEY=
