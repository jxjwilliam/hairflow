# Local ComfyUI (required for /api/comfyui/generate)
COMFYUI_URL=http://127.0.0.1:8188

# Generation results save to backend/output/ by default (no cloud storage configured)

# SQLite database path
# DATABASE_URL=sqlite+aiosqlite:///./hairstyle.db

# JWT settings (defaults are for dev only — change in production)
# JWT_SECRET_KEY=hairstyle-dev-secret-key-change-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_HOURS=24

# Dev flags
SKIP_POINTS_CHECK=true
DEV_MAGIC_CODE=888888
JWT_SECRET_KEY=hairstyle-dev-secret-key-change-in-production
