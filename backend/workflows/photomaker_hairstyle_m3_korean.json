{
  "_meta": {
    "title": "PhotoMaker Hairstyle — 韩式微分 (m3)",
    "description": "Men: Korean style two-block haircut. Prompt from templates_comfyui.json template m3."
  },
  "1": {
    "inputs": {"image": "example.png"},
    "class_type": "LoadImage",
    "_meta": {"title": "Upload your photo"}
  },
  "2": {
    "inputs": {"ckpt_name": "photon_v1.safetensors"},
    "class_type": "CheckpointLoaderSimple"
  },
  "3": {
    "inputs": {"photomaker_model_name": "photomaker-v1.bin"},
    "class_type": "PhotoMakerLoader"
  },
  "4": {
    "inputs": {
      "photomaker": ["3", 0],
      "image": ["1", 0],
      "clip": ["2", 1],
      "text": "photograph of a man with Korean style two-block haircut, soft parted bangs, slightly wavy medium length top, Korean drama actor style, studio lighting, portrait, Asian man, img"
    },
    "class_type": "PhotoMakerEncode",
    "_meta": {"title": "韩式微分 prompt"}
  },
  "5": {
    "inputs": {
      "text": "long hair, bald, messy unkempt hair, hat, blurry, low quality",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode"
  },
  "6": {
    "inputs": {"width": 512, "height": 768, "batch_size": 1},
    "class_type": "EmptyLatentImage"
  },
  "7": {
    "inputs": {
      "seed": 42, "steps": 25, "cfg": 6.5,
      "sampler_name": "euler_ancestral", "scheduler": "normal", "denoise": 0.8,
      "model": ["2", 0], "positive": ["4", 0], "negative": ["5", 0], "latent_image": ["6", 0]
    },
    "class_type": "KSampler"
  },
  "8": {
    "inputs": {"samples": ["7", 0], "vae": ["2", 2]},
    "class_type": "VAEDecode"
  },
  "9": {
    "inputs": {"filename_prefix": "hairstyle_m3_korean", "images": ["8", 0]},
    "class_type": "SaveImage"
  }
}
